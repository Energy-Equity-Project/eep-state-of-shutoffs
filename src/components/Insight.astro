---
import type { Insight } from '../data/insights';
import type { EndnoteRegistry, Segment } from '../lib/endnotes';
import { renderSegments } from '../lib/endnotes';
import { renderWithHighlights } from '../lib/highlight';
import AnimateOnEnter from './AnimateOnEnter';

interface Props {
  insight: Insight;
  total: number;
  registry?: EndnoteRegistry;
}

const { insight, total, registry } = Astro.props;

function toSegments(text: string, highlights: string[]): Segment[] {
  if (registry) return renderSegments(text, { highlights, registry });
  return renderWithHighlights(text, highlights).map((s): Segment =>
    s.highlight ? { type: 'highlight', text: s.text } : { type: 'text', text: s.text }
  );
}

const headlineSegments = toSegments(insight.headline, insight.headlineHighlights);
const statSegments = toSegments(insight.stat, insight.statHighlights);
const frameSegments = toSegments(insight.frame, []);
---

<AnimateOnEnter client:visible>
  <p class="text-xs font-semibold tracking-widest uppercase text-ink/40 mb-4">
    Insight {String(insight.number).padStart(2, '0')} of {String(total).padStart(2, '0')}
  </p>
  <h2 class="font-serif text-3xl md:text-4xl font-bold leading-tight mb-8">
    {headlineSegments.map((seg) =>
      seg.type === 'highlight' ? (
        <span class="highlight">{seg.text}</span>
      ) : seg.type === 'endnote' ? (
        <sup class="endnote-ref" id={seg.isFirst ? `endnote-ref-${seg.number}` : undefined}>
          <a href={`#endnote-${seg.number}`}>{seg.number}</a>
        </sup>
      ) : seg.text
    )}
  </h2>
  <p class="text-base leading-relaxed mb-6">
    <strong>Stat: </strong>{statSegments.map((seg) =>
      seg.type === 'highlight' ? (
        <span class="highlight">{seg.text}</span>
      ) : seg.type === 'endnote' ? (
        <sup class="endnote-ref" id={seg.isFirst ? `endnote-ref-${seg.number}` : undefined}>
          <a href={`#endnote-${seg.number}`}>{seg.number}</a>
        </sup>
      ) : seg.text
    )}
  </p>
  <p class="text-base leading-relaxed text-ink/80">
    <strong>Why this matters: </strong>{frameSegments.map((seg) =>
      seg.type === 'highlight' ? (
        <span class="highlight">{seg.text}</span>
      ) : seg.type === 'endnote' ? (
        <sup class="endnote-ref" id={seg.isFirst ? `endnote-ref-${seg.number}` : undefined}>
          <a href={`#endnote-${seg.number}`}>{seg.number}</a>
        </sup>
      ) : seg.text
    )}
  </p>
</AnimateOnEnter>
