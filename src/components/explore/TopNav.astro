---
import StateSelector from './StateSelector';

interface Props {
  currentCode: string;
}

const { currentCode } = Astro.props;
---

<nav class="flex justify-between items-center pb-4 border-b border-[--color-border-light] mb-6">
  <div class="flex gap-5 items-center">
    <a
      href="/"
      class="text-[13px] text-[--color-text-tertiary] hover:text-[--color-ink] transition-colors focus-visible:outline-2 focus-visible:outline-[--color-accent] rounded"
    >
      Home
    </a>
    <span class="text-[13px] text-[--color-ink] border-b border-current pb-0.5">
      Explore by state
    </span>
    <a
      href="/about"
      class="text-[13px] text-[--color-text-tertiary] hover:text-[--color-ink] transition-colors focus-visible:outline-2 focus-visible:outline-[--color-accent] rounded"
    >
      About the data
    </a>
  </div>
  <div class="min-w-[180px]">
    <StateSelector currentCode={currentCode} client:load />
  </div>
</nav>
