---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Masthead from '../../components/Masthead.astro';
import TopNav from '../../components/explore/TopNav.astro';

import KpiGrid from '../../components/explore/KpiGrid';
import MonthlyChart from '../../components/explore/MonthlyChart';
import WarningsVsDisconnections from '../../components/explore/WarningsVsDisconnections';
import CompareStates from '../../components/explore/CompareStates';
import {
  getAllStateCodes,
  getStateAnnual,
  getStateMonthly,
  getNationalRank,
  getMultiplierVsNational,
  getOneInX,
  getYear,
  getStateCost2024,
  getCostChange,
  STATE_CODES,
} from '../../lib/shutoffs';
import { formatMultiplier } from '../../lib/format';

export function getStaticPaths() {
  const codes = getAllStateCodes();
  return [
    ...codes.map((code) => ({ params: { code } })),
    ...codes.map((code) => ({ params: { code: code.toLowerCase() }, props: { canonical: code } })),
  ];
}

const { code: rawCode } = Astro.params;
const { canonical } = Astro.props as { canonical?: string };

// Redirect lowercase URLs to canonical uppercase
if (canonical) {
  return Astro.redirect(`/explore/${canonical}`, 301);
}

const code = rawCode.toUpperCase();
const stateName = STATE_CODES[code] ?? code;
const stateAnnual = getStateAnnual(code);
const stateMonthly = getStateMonthly(code);

const electricRank = getNationalRank(code, 'electric');
const electricMultiplier = getMultiplierVsNational(code, 'electric');
const oneInX = getOneInX(stateAnnual.electric_annual_shutoff_rate);
const year = getYear();
const totalStates = 51;

const ordinalSuffix = (n: number) => {
  const s = ['th', 'st', 'nd', 'rd'];
  const v = n % 100;
  return n + (s[(v - 20) % 10] ?? s[v] ?? s[0]);
};

const headline = `In ${stateName}, utilities disconnected electricity at ${Math.round(stateAnnual.electric_shutoffs_total).toLocaleString()} homes last year.`;
const subhead = `That's about 1 in every ${oneInX} customers — the ${ordinalSuffix(electricRank)} highest rate in the country, and roughly ${formatMultiplier(electricMultiplier)} the national average.`;

const cost = getStateCost2024(code);
const costChange = getCostChange(code);
const bill = cost?.avg_monthly_total_utility_cost ?? null;
const totalPct = costChange?.total_pct_change ?? null;

const costSubhead = bill == null
  ? null
  : totalPct == null
    ? `The average household here now pays $${Math.round(bill)} per month for electricity and gas.`
    : `The average household here now pays $${Math.round(bill)} per month for electricity and gas — ${totalPct >= 0 ? 'up' : 'down'} ${Math.round(Math.abs(totalPct))}% since 2020.`;
---

<BaseLayout title={`${stateName} utility shutoffs, ${year} — EEP`} hideTopRightMenu={true}>
  <Masthead titleAs="p" />
  <main class="max-w-[960px] mx-auto px-4 md:px-6 pt-28 pb-6">
    <div data-masthead-sentinel aria-hidden="true" style="height:1px;overflow:hidden;position:relative"></div>
    <TopNav currentCode={code} />

    <p class="text-[13px] text-[--color-text-tertiary] tracking-wide mb-2">
      {year} · Investor-owned utilities
    </p>
    <h1 class="text-[19px] md:text-[26px] font-medium leading-snug mb-3 max-w-2xl">
      {headline}
    </h1>
    <p class={`text-[15px] text-[--color-text-secondary] leading-relaxed ${costSubhead ? '' : 'mb-8'} max-w-2xl`}>
      {subhead}
    </p>
    {costSubhead && (
      <p class="text-[12px] md:text-[14px] text-[--color-text-tertiary] leading-relaxed mb-8 max-w-2xl">
        {costSubhead}
      </p>
    )}

    <KpiGrid
      stateAnnual={stateAnnual}
      stateCode={code}
      electricRank={electricRank}
      totalStates={totalStates}
      costBill2024={bill}
      costTotalPctChange={totalPct}
      client:load
    />

    <MonthlyChart
      stateMonthly={stateMonthly}
      stateName={stateName}
      stateCode={code}
      client:load
    />

    <WarningsVsDisconnections
      stateAnnual={stateAnnual}
      stateName={stateName}
      client:load
    />

    <CompareStates currentCode={code} client:load />

  </main>
</BaseLayout>
