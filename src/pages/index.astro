---
import BaseLayout from '../layouts/BaseLayout.astro';
import Counter from '../components/Counter';
---

<BaseLayout title="State of Shutoffs — EEP">
  <main class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="mb-6 text-4xl font-bold">State of Shutoffs</h1>
    <p class="mb-10 text-lg text-gray-700">
      Each year, millions of American households face utility disconnections — a quiet crisis that
      disproportionately affects low-income communities and communities of color. This project makes
      EIA-112 utility shutoff data legible to a general audience, combining guided narrative with
      state-by-state interactive exploration.
    </p>
    <div class="rounded border border-gray-200 p-6">
      <p class="mb-2 text-sm text-gray-500">React island — confirms hydration works:</p>
      <Counter client:load />
    </div>
  </main>
</BaseLayout>
